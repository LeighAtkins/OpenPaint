{
  "name": "openpaint",
  "version": "2.0.0",
  "packageManager": "bun@1.1.42",
  "type": "module",
  "description": "A web-based drawing and annotation tool designed for email communication of measurements and specifications",
  "main": "app.js",
  "engines": {
    "node": "24.x"
  },
  "scripts": {
    "start": "node app.js",
    "op": "node scripts/op-cli.mjs",
    "dev": "vite --config vite.config.ts --host",
    "dev:all": "node scripts/dev-all-safe.mjs",
    "dev:sam": "docker compose -f docker-compose.dev.yml up --build mos-sam",
    "sam:setup:local": "python3 -m pip install --user -r services/mos-sam/requirements.txt",
    "dev:sam:local": "bash -lc 'PY=python3; if [ -x .venv-mos-sam/bin/python ]; then PY=.venv-mos-sam/bin/python; fi; echo \"[mos-sam] python=$PY\"; echo \"[mos-sam] MOS_MODEL_PATH=${MOS_MODEL_PATH:-<unset>}\"; exec \"$PY\" -m uvicorn app:app --host 0.0.0.0 --port 8090 --app-dir services/mos-sam'",
    "dev:all:raw": "concurrently -k \"npm:dev:server\" \"npm:dev\"",
    "dev:all:safe": "node scripts/dev-all-safe.mjs",
    "dev:safe": "VITE_SAFE_DEV=1 vite --config vite.config.ts --host",
    "dev:server": "node app.js",
    "dev:legacy": "node app.js",
    "build": "tsc -b && vite build --config vite.config.ts",
    "build:css": "node scripts/ensure-public-css.js && npx --yes @tailwindcss/cli -i \"./css/tailwind.input.css\" -o \"./public/css/tailwind.build.css\" --minify",
    "build:profile:no-minify": "vite build --config vite.config.ts --minify false",
    "preview": "vite preview --config vite.config.ts",
    "build:vercel": "npm run build:css && vite build --config vite.config.ts",
    "deploy": "npx vercel --prod",
    "deploy:preview": "npx vercel",
    "type-check": "tsc --noEmit",
    "type-check:watch": "tsc --noEmit --watch",
    "lint": "eslint src --max-warnings 0",
    "lint:fix": "eslint src --fix",
    "lint:legacy": "eslint . --ignore-pattern src/",
    "format": "prettier --write \"src/**/*.{ts,tsx,json}\"",
    "format:check": "prettier --check \"src/**/*.{ts,tsx,json}\"",
    "test": "vitest --config vitest.config.ts run",
    "test:watch": "vitest --config vitest.config.ts",
    "test:ui": "vitest --config vitest.config.ts --ui",
    "test:coverage": "vitest --config vitest.config.ts run --coverage",
    "test:e2e": "npx playwright test --project=e2e",
    "test:e2e:headed": "npx playwright test --project=e2e --headed",
    "test:e2e:debug": "npx playwright test --project=e2e --debug",
    "test:visual": "node scripts/run-visual-tests.mjs",
    "test:visual:update": "node scripts/run-visual-tests.mjs --update-snapshots",
    "test:visual:setup": "playwright install --with-deps chromium",
    "capture:cw40:setup": "playwright install chromium",
    "capture:cw40": "node output/playwright/capture-cw40-endpoints.mjs",
    "parse:har": "node output/playwright/parse-har-endpoints.mjs",
    "validate": "npm run type-check && npm run lint && npm run test",
    "validate:full": "npm run type-check && npm run lint && npm run test:coverage",
    "db:generate-types": "npx --yes supabase@2.76.9 gen types typescript --linked > src/types/database.types.ts",
    "db:migrate": "npx --yes supabase@2.76.9 db push",
    "db:reset": "npx --yes supabase@2.76.9 db reset",
    "db:seed": "npx --yes supabase@2.76.9 db seed",
    "db:diff": "npx --yes supabase@2.76.9 db diff",
    "postinstall": "patch-package",
    "prepare": "node scripts/prepare-git-hooks.js",
    "precommit": "lint-staged",
    "clean": "rm -rf dist node_modules/.vite coverage",
    "nuke": "rm -rf node_modules dist coverage .husky/_"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.992.0",
    "@aws-sdk/s3-request-presigner": "^3.992.0",
    "@sparticuz/chromium": "^138.0.2",
    "@supabase/supabase-js": "^2.95.3",
    "@tailwindcss/postcss": "^4.1.17",
    "@vercel/postgres": "^0.10.0",
    "debug": "^4.4.3",
    "dotenv": "^17.2.3",
    "express": "^4.21.2",
    "fabric": "^5.3.0",
    "file-saver": "^2.0.5",
    "jszip": "^3.10.1",
    "ms": "^2.1.3",
    "multer": "^1.4.5-lts.2",
    "pako": "^2.1.0",
    "pdf-lib": "^1.17.1",
    "pg": "^8.16.3",
    "puppeteer-core": "^24.22.3",
    "sharp": "^0.34.5",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@parcel/watcher": "^2.5.1",
    "@playwright/test": "^1.58.2",
    "@tailwindcss/cli": "^4.1.17",
    "@types/fabric": "^5.3.11",
    "@types/node": "^24.10.1",
    "@typescript-eslint/eslint-plugin": "^8.48.0",
    "@typescript-eslint/parser": "^8.48.0",
    "@vitest/coverage-v8": "^4.1.0",
    "@vitest/ui": "^4.1.0",
    "autoprefixer": "^10.4.21",
    "baseline-browser-mapping": "^2.9.18",
    "concurrently": "^9.2.1",
    "esbuild": "^0.27.4",
    "eslint": "^8.57.1",
    "eslint-config-prettier": "^10.1.8",
    "globals": "^16.5.0",
    "happy-dom": "^17.6.1",
    "husky": "^9.1.7",
    "lint-staged": "^16.2.7",
    "patch-package": "^8.0.1",
    "pixelmatch": "^5.3.0",
    "playwright": "^1.58.2",
    "pngjs": "^7.0.0",
    "postcss": "^8.5.6",
    "prettier": "^3.6.2",
    "rollup": "npm:@rollup/wasm-node@^4.57.1",
    "tailwindcss": "^4.1.16",
    "terser": "^5.44.1",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.48.0",
    "vite": "^8.0.0",
    "vite-plugin-checker": "^0.11.0",
    "vitest": "^4.1.0"
  },
  "directories": {
    "doc": "docs",
    "test": "tests"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/LeighAtkins/OpenPaint.git"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "bugs": {
    "url": "https://github.com/LeighAtkins/OpenPaint/issues"
  },
  "homepage": "https://github.com/LeighAtkins/OpenPaint#readme"
}
