{
  "routes": [
    {
      "src": "^/favicon.ico$",
      "dest": "/favicon.ico"
    },
    {
      "src": "^/ai/(.*)$",
      "dest": "/api/[...all].js"
    },
    {
      "src": "^/api/(.*)$",
      "dest": "/api/[...all].js"
    },
    {
      "src": "^/(health|env-check|version|test)$",
      "dest": "/api/[...all].js"
    },
    {
      "src": "^/shared/(.*)$",
      "dest": "/api/[...all].js"
    },
    {
      "src": "^/js/(.*)$",
      "dest": "/js/$1"
    },
    {
      "src": "^/css/(.*)$",
      "dest": "/css/$1"
    },
    {
      "src": "^/src/(.*)$",
      "dest": "/src/$1"
    },
    {
      "src": "^/public/(.*)$",
      "dest": "/public/$1"
    },
    {
      "src": "^/(.*\\.(js|css|html|ico|png|jpg|jpeg|gif|svg|json))$",
      "dest": "/$1"
    },
    {
      "src": "^/(.*)$",
      "dest": "/api/[...all].js"
    }
  ]
}
