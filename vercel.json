{
  "installCommand": "npm ci --ignore-scripts",
  "buildCommand": "npm run build:vercel",
  "outputDirectory": "dist",
  "rewrites": [
    { "source": "/api/share-project", "destination": "/api/[...all]" },
    { "source": "/api/shared/:path*", "destination": "/api/[...all]" },
    { "source": "/api/cloud-projects/:path*", "destination": "/api/[...all]" },
    { "source": "/api/projects/:path*", "destination": "/api/[...all]" },
    { "source": "/api/cloud-assets/:path*", "destination": "/api/[...all]" },
    { "source": "/api/wallet/:path*", "destination": "/api/[...all]" },
    { "source": "/api/pets/:path*", "destination": "/api/[...all]" },
    { "source": "/shared/:shareId", "destination": "/api/[...all]" },
    { "source": "/open/:projectId", "destination": "/api/[...all]" },
    { "source": "/production/:shareId", "destination": "/api/[...all]" },
    { "source": "/wallet/:path*", "destination": "/api/[...all]" },
    { "source": "/pets/:path*", "destination": "/api/[...all]" }
  ],
  "functions": {
    "api/[...all].js": {
      "includeFiles": "{server/**,app.js,index.html,shared.html,shared.js,css/**,src/**,public/assets/**,public/css/**,public/favicon.ico}"
    },
    "api/integrations/cw/[action].js": {
      "includeFiles": "server/**"
    },
    "api/integrations/cw/[action]/[formId].js": {
      "includeFiles": "server/**"
    },
    "api/integrations/cw/images/[formId].js": {
      "includeFiles": "server/**"
    },
    "api/integrations/cw/images/[formId]/upload.js": {
      "includeFiles": "server/**"
    },
    "api/integrations/cw/images/[formId]/delete.js": {
      "includeFiles": "server/**"
    },
    "api/measurement-guides/svg.js": {
      "includeFiles": "server/**"
    },
    "api/storage/r2/[action].js": {
      "includeFiles": "server/**"
    },
    "api/measurements/generate.js": {
      "includeFiles": "server/**",
      "maxDuration": 60
    }
  }
}
