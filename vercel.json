{
  "version": 2,
  "builds": [
    {
      "src": "app.js",
      "use": "@vercel/node",
      "config": {
        "includeFiles": ["index.html", "shared.html", "uploads/**"]
      }
    },
    {
      "src": "public/**",
      "use": "@vercel/static"
    },
    {
      "src": "index.html",
      "use": "@vercel/static"
    },
    {
      "src": "shared.html",
      "use": "@vercel/static"
    },
    {
      "src": "css/**",
      "use": "@vercel/static"
    },
    {
      "src": "src/**",
      "use": "@vercel/static"
    },
    {
      "src": "diagnostics-overlay.js",
      "use": "@vercel/static"
    },
    {
      "src": "test-coordinate-system.js",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    {
      "src": "^/favicon.ico$",
      "dest": "/public/favicon.ico"
    },
    {
      "src": "^/ai/(.*)$",
      "dest": "/app.js"
    },
    {
      "src": "^/api/(.*)$",
      "dest": "/app.js"
    },
    {
      "src": "^/(health|env-check|version|test)$",
      "dest": "/app.js"
    },
    {
      "src": "^/js/(.*)$",
      "dest": "/public/js/$1"
    },
    {
      "src": "^/css/(.*)$",
      "dest": "/css/$1"
    },
    {
      "src": "^/src/(.*)$",
      "dest": "/src/$1"
    },
    {
      "src": "^/(diagnostics-overlay|test-coordinate-system)\\.js$",
      "dest": "/$1.js"
    },
    {
      "src": "^/$",
      "dest": "/index.html"
    },
    {
      "src": "^/shared/(.*)$",
      "dest": "/app.js"
    },
    {
      "src": ".*",
      "dest": "/app.js"
    }
  ]
}