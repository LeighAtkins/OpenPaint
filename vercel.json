{
  "functions": {
    "api/**/*.js": {
      "includeFiles": "{css/**,js/**,public/**,*.html,favicon.ico,src/**/*.{ts,js,css}}"
    }
  },
  "routes": [
    {
      "src": "^/favicon.ico$",
      "dest": "/favicon.ico"
    },
    {
      "src": "^/api/upload-project$",
      "dest": "/api/app.js"
    },
    {
      "src": "^/api/(.*)$",
      "dest": "/api/app.js"
    },
    {
      "src": "^/js/(.*)$",
      "dest": "/js/$1"
    },
    {
      "src": "^/css/(.*)$",
      "dest": "/css/$1"
    },
    {
      "src": "^/src/(.*)$",
      "dest": "/src/$1"
    },
    {
      "src": "^/public/(.*)$",
      "dest": "/public/$1"
    },
    {
      "src": "^/(.*\\.(js|css|html|ico|png|jpg|jpeg|gif|svg|json|ts))$",
      "dest": "/$1"
    },
    {
      "src": "^/(.*)$",
      "dest": "/api/app.js"
    }
  ]
}
