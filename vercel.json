{
  "version": 2,
  "builds": [
    {
      "src": "api-proxy.js",
      "use": "@vercel/node"
    },
    {
      "src": "public/**",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    {
      "src": "^/api/_env$",
      "dest": "/api-proxy.js"
    },
    {
      "src": "^/api/images/direct-upload$",
      "dest": "/api-proxy.js"
    },
    {
      "src": "^/api/remove-background$",
      "dest": "/api-proxy.js"
    },
    {
      "src": "^/api/(.*)$",
      "dest": "/api-proxy.js"
    },
    {
      "src": "^/(.*)",
      "dest": "/public/$1"
    }
  ]
}