{
    "version": 2,
    "builds": [
        {
            "src": "app.js",
            "use": "@vercel/node"
        },
        {
            "src": "index.html",
            "use": "@vercel/static"
        },
        {
            "src": "public/**",
            "use": "@vercel/static"
        },
        {
            "src": "css/**",
            "use": "@vercel/static"
        },
        {
            "src": "js/**",
            "use": "@vercel/static"
        },
        {
            "src": "src/**",
            "use": "@vercel/static"
        }
    ],
    "routes": [
        {
            "src": "^/ai/(.*)$",
            "dest": "/app.js"
        },
        {
            "src": "^/api/(.*)$",
            "dest": "/app.js"
        },
        {
            "src": "^/(health|env-check|version|test)$",
            "dest": "/app.js"
        },
        {
            "src": "^/js/(.*)$",
            "dest": "/js/$1"
        },
        {
            "src": "^/css/(.*)$",
            "dest": "/css/$1"
        },
        {
            "src": "^/src/(.*)$",
            "dest": "/src/$1"
        },
        {
            "src": "^/public/(.*)$",
            "dest": "/public/$1"
        },
        {
            "src": "^/favicon.ico$",
            "dest": "/public/favicon.ico"
        },
        {
            "src": "^/$",
            "dest": "/app.js"
        },
        {
            "src": "/(.*)",
            "dest": "/app.js"
        }
    ]
}