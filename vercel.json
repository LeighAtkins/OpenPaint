{
  "version": 2,
  "builds": [
    {
      "src": "app.js",
      "use": "@vercel/node"
    },
    {
      "src": "public/**",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    {
      "src": "^/ai/(.*)$",
      "dest": "/app.js"
    },
    {
      "src": "^/api/(.*)$",
      "dest": "/app.js"
    },
    {
      "src": "^/(health|env-check|version|test)$",
      "dest": "/app.js"
    },
    {
      "src": "^/uploads/(.*)$",
      "dest": "/app.js"
    },
    {
      "src": "^/projects/(.*)$",
      "dest": "/app.js"
    },
    {
      "src": "^/$",
      "dest": "/app.js"
    }
  ]
}