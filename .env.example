# Environment Variables Template
# Copy this to .env.development and fill in your actual values

# Supabase Configuration (optional during migration)
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# Feature flags
VITE_ENABLE_AUTH=false

# Development flags
VITE_DEV_MODE=true
VITE_TYPESCRIPT_MIGRATION=true

# Gemini API (for MOS overlay generation)
GEMINI_API_KEY=your-gemini-api-key-here
GEMINI_MODEL=gemini-2.0-flash

# MOS generation strategy: auto | gemini | sam
MOS_GENERATE_STRATEGY=auto

# Local Python service for SAM-style deterministic tracking
MOS_SAM_SERVICE_URL=http://localhost:8090

# Optional: enable NN keypoint model in mos-sam service (otherwise heuristic fallback)
MOS_MODEL_PATH=/absolute/path/to/pose/weights/best.pt
