# Exclude client-side JavaScript from serverless function detection
# These files should be served as static assets, not compiled as serverless functions
js/ai-schemas.js
js/ai-style-guide.js
js/ai-export.js
js/coordinate-validator.js
js/ai-worker-mock.js
public/js/ai-schemas.js
public/js/ai-style-guide.js
public/js/ai-export.js
public/js/coordinate-validator.js
public/js/ai-worker-mock.js

# Exclude unused API files (only api/[...all].js should be built as a serverless function)
api/app.js
api/app-simple.js
api/db.js
api/index.js
api/test.js
api/rembg.ts
api/images/

# Exclude TypeScript source files and tests
src/**/*.test.ts
src/**/__tests__/
src/canvas/viewport/useCanvasViewport.ts
src/canvas/viewport/__tests__/

# Exclude test and development files
test-*.js
debug-*.js
*_backup.js
*_temp.js
*_corrupted.js
*.test.js
*.spec.js
tests/
cypress/

# Exclude documentation
*.md
CLAUDE.md
